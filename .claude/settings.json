{
  "enabledPlugins": {
  },
  "worktree": {
    "baseRef": "head"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/hook-block-middleware.mjs",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
