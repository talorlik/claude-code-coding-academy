# .env.example — Eyal's Coding Academy
#
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored and MUST NOT be committed.
# This file is committed: placeholders only, no real values.
#
# Vercel env-var checklist: every variable below must be set in the
# Vercel project settings before the first production deploy.
# Test vars (E2E_*) are NOT needed in Vercel — they are local-only.

# ─── Required ────────────────────────────────────────────────────────────────

# Supabase project URL (client + server).
# Found in Supabase dashboard → Project Settings → API → Project URL.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase publishable (anon) key (client + server).
# Found in Supabase dashboard → Project Settings → API → anon/public key.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Supabase secret (service_role) key — SERVER ONLY.
# Never prefix with NEXT_PUBLIC_. Never import in "use client" files.
# Found in Supabase dashboard → Project Settings → API → service_role key.
SUPABASE_SECRET_KEY=sb_secret_...

# Vercel AI Gateway API key — SERVER ONLY.
# Auto-detected by @ai-sdk/gateway when set. Powers /api/tutor.
# Never prefix with NEXT_PUBLIC_. Never import in "use client" files.
# Found in Vercel dashboard → AI → Gateway → API Keys.
AI_GATEWAY_API_KEY=...

# Canonical base URL of the app (client + server).
# Used for SEO canonical tags, Open Graph, sitemap, and auth redirects.
# Locally: http://localhost:3000. In Vercel: https://your-domain.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Deprecated alias - kept for backward compatibility during transitional
# period. All code now reads NEXT_PUBLIC_APP_URL via getSiteUrl().
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Optional ─────────────────────────────────────────────────────────────────

# Cloudflare Turnstile site key — client-side (NEXT_PUBLIC_).
# The Turnstile widget is NOT currently wired into the auth forms
# (disabled per batch-00 decision). Set these when you enable it.
# Found in Cloudflare dashboard → Turnstile → your site.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Cloudflare Turnstile secret — SERVER ONLY.
# Required if backend Turnstile verification is enabled.
TURNSTILE_SECRET_KEY=

# YouTube Data API v3 key — SERVER ONLY.
# Required for playlist import and richer lesson metadata.
# Found in Google Cloud Console → APIs & Services → Credentials.
YOUTUBE_API_KEY=

# Email delivery provider API key — SERVER ONLY.
# Required if reminder emails are delivered via an external provider
# (Resend, SendGrid, Mailgun, etc.). Without it the reminders system
# queues reminders and marks them visible but does NOT send emails —
# this is the current shipped behavior (no email provider configured).
EMAIL_PROVIDER_API_KEY=

# ─── SMTP (Gmail) — SERVER ONLY ───────────────────────────────────────────────
#
# Used by lib/email/transport.ts (nodemailer) for transactional reminder emails.
# ALL four vars are server-only: never prefix with NEXT_PUBLIC_, never import
# in "use client" files, never log SMTP_PASSWORD anywhere.
#
# Gmail setup:
#   1. Enable 2-Step Verification on the Gmail account.
#   2. Go to Google Account → Security → App Passwords.
#   3. Generate a 16-character App Password (no spaces needed - they are stripped).
#   4. Use smtp.gmail.com on port 465 (implicit TLS / SMTPS, secure:true) or
#      port 587 (STARTTLS, secure:false). Port 465 is recommended.
#
# Throughput: personal Gmail allows ~500 sends/day.
# For higher volume use a transactional provider (Resend, SendGrid) and set
# SMTP_HOST to their SMTP relay instead.
#
# If any of the four required vars below is missing the app degrades to
# queue-only mode: reminders are queued but the Send button returns a safe
# error - no crash.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# Optional: override the From address shown to recipients.
# Defaults to SMTP_USER when not set.
EMAIL_FROM=

# ─── E2E / Test (local only — do NOT set in Vercel) ──────────────────────────

# Base URL the Playwright suite targets. Defaults to http://localhost:3100.
E2E_BASE_URL=http://localhost:3100

# Alternate port for the E2E dev server (default: 3100).
E2E_PORT=3100

# Seeded test accounts created by `npm run seed`.
# Used by Playwright for auth flows. Not required for unit tests.
E2E_STUDENT_EMAIL=student@example.com
E2E_STUDENT_PASSWORD=change-me

# Instructor / admin test account.
E2E_INSTRUCTOR_EMAIL=instructor@example.com
E2E_INSTRUCTOR_PASSWORD=change-me

# Set to "1" to run tests that call the real Vercel AI Gateway.
# Leave unset (default) to skip live-AI tests in CI.
E2E_REAL_AI=
