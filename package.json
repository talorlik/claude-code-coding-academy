{
  "name": "claude-code-coding-academy",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "guard:proxy": "node scripts/guard-no-middleware.mjs",
    "predev": "node scripts/guard-no-middleware.mjs",
    "dev": "next dev --turbopack",
    "prebuild": "node scripts/guard-no-middleware.mjs && node scripts/check-i18n-sync.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:i18n": "node scripts/check-i18n-sync.mjs",
    "seed": "node scripts/seed.mjs",
    "backup": "bash scripts/backup-supabase.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "pretypecheck": "node scripts/guard-no-middleware.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.128",
    "@ai-sdk/react": "^3.0.204",
    "@base-ui/react": "^1.4.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "ai": "^6.0.202",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.8.0",
    "next": "16.1.7",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.11",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.10.0",
    "recharts": "^3.8.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.3.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.7",
    "jsdom": "^29.1.1",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
